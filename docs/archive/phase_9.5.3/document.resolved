# Blueprint de Correção — Fase 9.5.3 (Micro-Tarefas Cirúrgicas)

## Contexto

Cinco seções do PRD_FINAL falham porque recebem contexto cruzado excessivo. Duas seções aparecem duplicadas. O consistency_checker não conta sub-headers. O PRD_REVIEW falha na validação por mismatch de headers. A validação PLACEHOLDER_HEAVY dispara por campos "A DEFINIR".

O princípio desta fase é cirúrgico: resolver cada falha com a menor alteração possível, sem reescrever a arquitetura. Cada correção é independente e pode ser commitada separadamente.

---

## W1b-01: Extratores de Contexto Mínimo

### Problema

As 5 seções que falham recebem artefatos inteiros como contexto. O modelo 20B não consegue processar e retorna vazio.

### Solução

Criar módulo `src/core/context_extractors.py` com funções que extraem apenas o trecho relevante de cada artefato-fonte, limitado a 400 tokens (~1600 chars).

### Arquivo novo: `src/core/context_extractors.py`

```python
"""
Extratores de contexto mínimo para passagens do sectional_generator.
Cada extrator recebe o conteúdo completo de um artefato e retorna
apenas o trecho relevante para uma seção específica do PRD_FINAL.
"""
import re
from typing import Optional


def _extract_section(content: str, header: str, max_chars: int = 1600) -> str:
    """Extrai conteúdo sob um header markdown ## ou ###."""
    pattern = rf"(#{2,3}\s*{re.escape(header)}.*?)(?=\n#{2,3}\s|\Z)"
    match = re.search(pattern, content, re.DOTALL)
    if match:
        text = match.group(1).strip()
        if len(text) > max_chars:
            return text[:max_chars] + "\n[...truncado]"
        return text
    return ""


def _extract_table(content: str, header: str, max_chars: int = 1600) -> str:
    """Extrai uma tabela markdown que aparece após um header."""
    section = _extract_section(content, header, max_chars=max_chars * 2)
    if not section:
        return ""
    # Encontrar linhas de tabela (começam com |)
    lines = section.split("\n")
    table_lines = [l for l in lines if l.strip().startswith("|")]
    if table_lines:
        result = "\n".join(table_lines)
        if len(result) > max_chars:
            return result[:max_chars] + "\n[...truncado]"
        return result
    return section[:max_chars]


def extract_for_arquitetura_tech_stack(system_design: str) -> str:
    """Extrai Tech Stack e Arquitetura Geral do system_design."""
    parts = []
    
    # Extrair tabela de Tech Stack
    tech_stack = _extract_table(system_design, "Tech Stack", max_chars=800)
    if tech_stack:
        parts.append("## Tech Stack (do System Design)\n" + tech_stack)
    
    # Extrair Arquitetura Geral (containers e comunicação)
    arq = _extract_section(system_design, "Arquitetura Geral", max_chars=600)
    if arq:
        parts.append(arq)
    
    return "\n\n".join(parts) if parts else "[Nenhum dado de system_design disponível]"


def extract_for_plano_implementacao(development_plan: str) -> str:
    """Extrai Fases de Implementação e Módulos Core do development_plan."""
    parts = []
    
    fases = _extract_table(development_plan, "Fases de Implementa", max_chars=800)
    if fases:
        parts.append("## Fases (do Development Plan)\n" + fases)
    
    modulos = _extract_table(development_plan, "Módulos Core", max_chars=600)
    if not modulos:
        modulos = _extract_table(development_plan, "M\u00f3dulos Core", max_chars=600)
    if modulos:
        parts.append("## Módulos Core\n" + modulos)
    
    return "\n\n".join(parts) if parts else "[Nenhum dado de development_plan disponível]"


def extract_for_decisoes_debate(debate_transcript: str) -> str:
    """Extrai tabela de Decisões Aplicáveis do debate_transcript."""
    # Procurar a tabela de síntese no final do transcript
    decisoes = _extract_table(debate_transcript, "Decisões Aplicáveis", max_chars=1400)
    if decisoes:
        return "## Decisões do Debate (síntese)\n" + decisoes
    
    # Fallback: procurar por "Decisões" ou "decisões"
    decisoes = _extract_table(debate_transcript, "Decis", max_chars=1400)
    if decisoes:
        return "## Decisões do Debate (síntese)\n" + decisoes
    
    return "[Nenhuma tabela de decisões encontrada no debate]"


def extract_for_guia_replicacao(development_plan: str) -> str:
    """Extrai Dependências Técnicas e Configurações de Ambiente."""
    parts = []
    
    deps = _extract_table(development_plan, "Dependências Técnicas", max_chars=600)
    if not deps:
        deps = _extract_table(development_plan, "Depend\u00eancias T\u00e9cnicas", max_chars=600)
    if deps:
        parts.append("## Dependências\n" + deps)
    
    env = _extract_table(development_plan, "Configurações de Ambiente", max_chars=400)
    if not env:
        env = _extract_table(development_plan, "Configura\u00e7\u00f5es de Ambiente", max_chars=400)
    if env:
        parts.append("## Ambiente\n" + env)
    
    guia = _extract_section(development_plan, "Guia de Replicação", max_chars=400)
    if not guia:
        guia = _extract_section(development_plan, "Guia de Replica", max_chars=400)
    if guia:
        parts.append(guia)
    
    return "\n\n".join(parts) if parts else "[Nenhum dado de replicação disponível]"


def generate_clausula_integridade(
    prd_final_chars: int,
    total_sections: int,
    failed_sections: int,
    model_name: str,
    generated_at: str
) -> str:
    """
    Gera Cláusula de Integridade como template estático.
    NÃO usa LLM — preenchimento determinístico.
    """
    status = "COMPLETO" if failed_sections == 0 else f"INCOMPLETO ({failed_sections} seções falharam)"
    
    return f"""## Cláusula de Integridade

| Campo | Valor |
|---|---|
| Status do Documento | {status} |
| Total de Seções | {total_sections} |
| Seções Geradas | {total_sections - failed_sections} |
| Seções Falhadas | {failed_sections} |
| Tamanho Total | {prd_final_chars:,} caracteres |
| Modelo Utilizado | {model_name} |
| Gerado em | {generated_at} |
| Versão do Pipeline | IdeaForge CLI — Fase 9.5.3 |

Este documento foi gerado automaticamente pelo pipeline IdeaForge.
Todas as seções passaram por validação estrutural via consistency_checker.
Dados técnicos foram derivados dos artefatos: system_design, security_review,
debate_transcript e development_plan."""
```

### Modificação em `sectional_generator.py`

Localizar onde cada passagem que falha é executada e substituir o input completo pelo extrator correspondente.

```python
# CONCEITUAL — adaptar à estrutura real do código

from src.core.context_extractors import (
    extract_for_arquitetura_tech_stack,
    extract_for_plano_implementacao,
    extract_for_decisoes_debate,
    extract_for_guia_replicacao,
    generate_clausula_integridade,
)

# No mapeamento de passagens ou no método que monta o contexto de cada pass:

# Para a passagem "Arquitetura e Tech Stack":
# ANTES: context = self.artifacts["system_design"].content  (inteiro, ~4500 chars)
# DEPOIS:
context = extract_for_arquitetura_tech_stack(self.artifacts["system_design"].content)

# Para "Plano de Implementação":
context = extract_for_plano_implementacao(self.artifacts["development_plan"].content)

# Para "Decisões do Debate":
context = extract_for_decisoes_debate(self.artifacts["debate_transcript"].content)

# Para "Guia de Replicação Resumido":
context = extract_for_guia_replicacao(self.artifacts["development_plan"].content)

# Para "Cláusula de Integridade":
# NÃO chamar LLM — usar template direto
clausula = generate_clausula_integridade(
    prd_final_chars=len(prd_content),
    total_sections=total_sections,
    failed_sections=count_failed,
    model_name=self.model_name,
    generated_at=datetime.now().isoformat()
)
# Inserir clausula diretamente no PRD_FINAL sem passar pelo modelo
```

