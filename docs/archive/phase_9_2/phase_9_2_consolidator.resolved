## Seção 8 — Testes obrigatórios

Atualizar `test_phase_9_1.py`:

```python
def test_12_passes_defined(self):
    self.assertEqual(len(NEXUS_FINAL_PASSES), 12)

def test_all_20_sections_covered(self):
    validator = OutputValidator()
    required = set(validator.REQUIRED_SECTIONS["prd_final"])
    covered = set()
    for p in NEXUS_FINAL_PASSES:
        for section in p.sections:
            covered.add(section)
    missing = required - covered
    self.assertEqual(len(missing), 0, f"Seções não cobertas: {missing}")

def test_no_duplicate_sections(self):
    all_sections = []
    for p in NEXUS_FINAL_PASSES:
        all_sections.extend(p.sections)
    self.assertEqual(len(all_sections), len(set(all_sections)))

def test_all_passes_have_context_artifacts(self):
    """Cada pass deve especificar quais artefatos precisa."""
    for p in NEXUS_FINAL_PASSES:
        self.assertIsInstance(p.context_artifacts, list,
            f"Pass {p.pass_id} sem context_artifacts")
        self.assertGreater(len(p.context_artifacts), 0,
            f"Pass {p.pass_id} com context_artifacts vazio")

def test_pass_ids_start_with_final(self):
    for p in NEXUS_FINAL_PASSES:
        self.assertTrue(p.pass_id.startswith("final"),
            f"Pass {p.pass_id} não começa com 'final'")

def test_max_output_tokens_reasonable(self):
    for p in NEXUS_FINAL_PASSES:
        self.assertGreaterEqual(p.max_output_tokens, 800)
        self.assertLessEqual(p.max_output_tokens, 1500)

def test_generate_sectional_with_inputs_exists(self):
    """Verifica que o método novo existe no SectionalGenerator."""
    from src.core.sectional_generator import SectionalGenerator
    mock_provider = MagicMock()
    gen = SectionalGenerator(mock_provider)
    self.assertTrue(hasattr(gen, 'generate_sectional_with_inputs'))
```

