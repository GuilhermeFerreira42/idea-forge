## Seção 3 — Campo `context_artifacts` no `SectionPass`

Mudança mínima no construtor de `SectionPass` em `sectional_generator.py`:

```python
class SectionPass:
    def __init__(self, pass_id: str, sections: List[str],
                 template: str, example: str,
                 instruction: str, max_output_tokens: int = 800,
                 require_table: bool = True,
                 min_chars: int = 80,
                 input_budget: int = 600,
                 context_artifacts: List[str] = None):
        self.pass_id = pass_id
        self.sections = sections
        self.template = template
        self.example = example
        self.instruction = instruction
        self.max_output_tokens = max_output_tokens
        self.require_table = require_table
        self.min_chars = min_chars
        self.input_budget = input_budget
        self.context_artifacts = context_artifacts or []
```

O campo `context_artifacts` é uma lista de nomes de artefatos (ex: `["prd", "system_design"]`). Se vazia, o pass usa o `user_input` completo (comportamento atual). Se preenchida, o `consolidate_prd` monta contexto seletivo.

---

## Seção 4 — `consolidate_prd()` atualizado

Diff do método em `product_manager_agent.py`:

```python
def consolidate_prd(self, artifacts_context: str, original_idea: str = "") -> str:
    """
    FASE 9.2: Consolida todos os artefatos em PRD Final via 12 passes granulares.
    Cada pass recebe contexto seletivo baseado em context_artifacts.
    """
    from src.core.sectional_generator import SectionalGenerator, NEXUS_FINAL_PASSES

    generator = SectionalGenerator(
        provider=self.provider,
        direct_mode=self.direct_mode
    )

    # Montar input base: ideia original + contexto completo
    combined_input = ""
    if original_idea:
        combined_input += f"IDEIA ORIGINAL:\n{original_idea[:500]}\n\n"
    combined_input += f"ARTEFATOS DO PIPELINE (sintetize, NÃO copie):\n{artifacts_context}"

    # FASE 9.2: Montar contexto seletivo por pass
    # Parsear artefatos do contexto para extração seletiva
    artifact_sections = self._parse_artifact_sections(artifacts_context)

    # Gerar passes com contexto seletivo
    passes = NEXUS_FINAL_PASSES
    pass_inputs = []
    for p in passes:
        if p.context_artifacts:
            # Montar contexto seletivo: apenas artefatos listados
            selective_context = ""
            if original_idea:
                selective_context += f"IDEIA ORIGINAL:\n{original_idea[:300]}\n\n"
            for art_name in p.context_artifacts:
                if art_name in artifact_sections:
                    selective_context += f"--- {art_name.upper()} ---\n{artifact_sections[art_name][:2000]}\n\n"
            pass_inputs.append(selective_context)
        else:
            pass_inputs.append(combined_input)

    # Usar generate_sectional com inputs por pass
    result = generator.generate_sectional_with_inputs(
        artifact_type="prd_final",
        pass_inputs=pass_inputs,
        passes=passes,
    )

    if result and len(result) > 500:
        return result

    # Fallback: chamada única
    return self._consolidate_single_pass(artifacts_context, original_idea)

def _parse_artifact_sections(self, artifacts_context: str) -> dict:
    """Parseia o contexto de artefatos em seções nomeadas."""
    sections = {}
    current_name = None
    current_content = []

    for line in artifacts_context.split('\n'):
        if line.strip().startswith('=== ARTIFACT:'):
            if current_name and current_content:
                sections[current_name] = '\n'.join(current_content)
            # Extrair nome: "=== ARTIFACT: prd (v1, document) ==="
            parts = line.split('ARTIFACT:')
            if len(parts) > 1:
                name_part = parts[1].split('(')[0].strip()
                current_name = name_part.lower().replace(' ', '_')
                current_content = []
        elif line.strip().startswith('=== END ARTIFACT'):
            if current_name and current_content:
                sections[current_name] = '\n'.join(current_content)
            current_name = None
            current_content = []
        elif current_name is not None:
            current_content.append(line)

    if current_name and current_content:
        sections[current_name] = '\n'.join(current_content)

    return sections
```

---

## Seção 5 — Novo método no `SectionalGenerator`

Adicionar ao `SectionalGenerator` em `sectional_generator.py`:

```python
def generate_sectional_with_inputs(self, artifact_type: str,
                                    pass_inputs: List[str],
                                    passes: List[SectionPass]) -> Optional[str]:
    """
    FASE 9.2: Gera artefato com input diferente por pass (contexto seletivo).
    """
    if not passes or len(passes) != len(pass_inputs):
        return None

    accumulated_output = ""
    pass_results = []
    failed_passes = 0

    for i, section_pass in enumerate(passes):
        self._emit(f"[PASS {i+1}/{len(passes)}] "
                   f"Gerando: {', '.join(section_pass.sections)}")

        result = self._execute_pass_with_retry(
            section_pass=section_pass,
            user_input=pass_inputs[i],
            context="",
            previous_output=accumulated_output,
            pass_number=i + 1,
            total_passes=len(passes),
        )

        if result is None:
            failed_passes += 1
            self._emit_warn(
                f"Pass {i+1} FALHOU. Seções: {section_pass.sections}"
            )
            failed_marker = "\n".join(
                f"{s}\n- [GERAÇÃO FALHOU — seção não produzida pelo modelo]"
                for s in section_pass.sections
            )
            pass_results.append(failed_marker)
        else:
            pass_results.append(result)
            accumulated_output += result + "\n\n"

    if failed_passes > len(passes) / 2:
        self._emit_warn(f"FALHA ESTRUTURAL: {failed_passes}/{len(passes)} passes falharam.")
        return None

    final_output = "\n\n".join(pass_results)

    validation = self.validator.validate(final_output, artifact_type)
    if validation.get("valid"):
        self._emit_ok(
            f"Artefato aprovado — density: {validation['density_score']:.2f}, "
            f"completude: {int(validation['completeness_score']*100)}%"
        )
    else:
        self._emit_warn(f"Artefato com problemas: {validation.get('fail_reasons', [])}")

    return final_output
```

