        ),
        instruction=(
            "Princípios: cada um DEVE ter coluna 'Regra Verificável' com texto 'REGRA:'.\n"
            "Diferenciais: compare com concorrentes reais ou abordagem manual atual."
        ),
        min_chars=300,
        max_output_tokens=1200,
        input_budget=2000,
