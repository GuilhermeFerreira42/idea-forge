EXEMPLAR_P01 = (
    "REFERÊNCIA DE PROFUNDIDADE (use como guia de densidade, NÃO copie):\n\n"
    "## Visão do Produto\n"
    "| Atributo | Valor |\n"
    "|---|---|\n"
