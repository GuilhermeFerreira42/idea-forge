    "| RF-02 | frontend-nextjs | app/produto/[slug]/page.tsx | "
    "test_product_page.spec.ts::test_isr | Header x-nextjs-cache = HIT ou STALE |\n"
    "| RF-05 | frontend + backend | OfferCard.tsx + clicks.py | "
    "test_affiliate_click.spec.ts | Click gera registro + nova aba com UTM |\n"
    "| RF-07 | frontend-nextjs | app/sitemap.ts | "
