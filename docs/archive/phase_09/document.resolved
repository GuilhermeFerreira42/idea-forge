        # 16/20 = 0.80 — acima do threshold 0.70, então ainda é válido
        self.assertTrue(res["valid"], f"Falha: {res.get('fail_reasons')}")
        # Mas as 4 seções novas devem estar em missing_sections
        missing = res.get("missing_sections", [])
        self.assertIn("## Matriz de Rastreabilidade", missing)
        self.assertIn("## Limitações Conhecidas", missing)
        self.assertIn("## Guia de Replicação Resumido", missing)
        self.assertIn("## Cláusula de Integridade", missing)
```

