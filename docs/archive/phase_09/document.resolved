## 1. Novo Arquivo: `src/agents/consistency_checker_agent.py`

```python
"""
consistency_checker_agent.py — Agente de Verificação de Consistência Interna.

FASE 9.0:
Responsabilidade:
    Auditar o PRD Final programaticamente (SEM LLM) para detectar:
    - IDs de RF referenciados que não existem na tabela de RFs
    - Seções com marcadores de falha ou conteúdo insuficiente
    - Contradições de stack tecnológica entre texto e tabelas

Contrato:
    Input: prd_final (string) + artifacts_context (string opcional)
    Output: Relatório de consistência em Markdown (string)

100% programático — zero chamadas LLM. Regex + string matching.
NÃO contém lógica de negócio de geração. Apenas audita.
"""

import re
from typing import List, Dict, Set, Tuple


class ConsistencyCheckerAgent:
    """Verifica integridade interna do PRD Final contra si mesmo e artefatos do pipeline."""

    # Tecnologias que frequentemente geram contradições
    TECH_GROUPS = {
        "database": [
            "postgresql", "postgres", "mysql", "mongodb", "sqlite",
            "dynamodb", "supabase", "redis", "mariadb", "cockroachdb"
        ],
        "framework_backend": [
            "fastapi", "django", "flask", "express", "nestjs",
            "spring", "rails", "laravel", "next.js", "nuxt.js"
        ],
        "framework_frontend": [
            "react", "vue", "angular", "svelte", "next.js",
            "nuxt.js", "remix", "astro", "solid"
        ],
        "language": [
            "python", "typescript", "javascript", "java", "go",
            "rust", "ruby", "php", "c#", "kotlin"
        ],
    }

    def check_consistency(self, prd_final: str, artifacts_context: str = "") -> str:
        """
        FASE 9.0: Verificação programática de consistência.

        Args:
            prd_final: Conteúdo completo do PRD Final consolidado.
            artifacts_context: Contexto dos artefatos anteriores (opcional).

        Returns:
            Relatório Markdown com achados estruturados.
        """
        if not prd_final or len(prd_final.strip()) < 100:
            return (
                "## Relatório de Consistência\n\n"
                "### ❌ PRD Final Vazio ou Insuficiente\n"
                "O PRD Final não contém conteúdo suficiente para auditoria.\n\n"
                "- **is_clean:** False\n"
            )

        issues_found = []
        report_sections = []

        # ═══ Check 1: IDs de RF Fantasmas ═══
        orphan_result = self._check_orphan_rfs(prd_final)
        if orphan_result:
            issues_found.append(orphan_result["summary"])
            report_sections.append(orphan_result["report"])

        # ═══ Check 2: Seções com Falha ou Insuficientes ═══
        sections_result = self._check_failed_sections(prd_final)
        if sections_result:
            issues_found.append(sections_result["summary"])
            report_sections.append(sections_result["report"])

        # ═══ Check 3: Seções Finas (< 50 chars de conteúdo) ═══
        thin_result = self._check_thin_sections(prd_final)
        if thin_result:
            issues_found.append(thin_result["summary"])
            report_sections.append(thin_result["report"])

        # ═══ Check 4: Contradições de Stack Tecnológica ═══
        tech_result = self._check_tech_contradictions(prd_final)
        if tech_result:
            issues_found.append(tech_result["summary"])
            report_sections.append(tech_result["report"])

        # ═══ Check 5: RNFs sem Métrica Quantitativa ═══
        rnf_result = self._check_rnf_metrics(prd_final)
        if rnf_result:
            issues_found.append(rnf_result["summary"])
            report_sections.append(rnf_result["report"])

        # ═══ Montar Relatório Final ═══
        is_clean = len(issues_found) == 0
        has_critical = any("CRITICAL" in i for i in issues_found)

        report_lines = ["## Relatório de Consistência\n"]

        if report_sections:
            report_lines.extend(report_sections)

        report_lines.append("### Resultado Final\n")
        if is_clean:
            report_lines.append("✅ PRD Final está consistente internamente.\n")
        else:
            report_lines.append(f"{'❌' if has_critical else '⚠️'} "
                                f"{len(issues_found)} categoria(s) de problema encontrada(s):\n")
            for issue in issues_found:
                report_lines.append(f"- {issue}")
            report_lines.append("")

        report_lines.append(f"- **is_clean:** {is_clean}")
        report_lines.append(f"- **has_critical:** {has_critical}")
        report_lines.append(f"- **checks_executados:** 5")
        report_lines.append(f"- **categorias_com_problema:** {len(issues_found)}")

        return "\n".join(report_lines)

    # ═══════════════════════════════════════════════════════
    # CHECKS INDIVIDUAIS
    # ═══════════════════════════════════════════════════════

    def _check_orphan_rfs(self, text: str) -> Dict | None:
        """
        Detecta IDs RF-XX referenciados no texto que não existem
        na tabela de Requisitos Funcionais.
        """
        defined_rfs = self._extract_defined_rf_ids(text)
        all_referenced_rfs = self._extract_all_rf_references(text)

        # Orphans = referenciados mas não definidos
        orphans = sorted(all_referenced_rfs - defined_rfs)

        if not orphans:
            return None

        report = "### ❌ IDs de Requisitos Fantasmas (CRITICAL)\n\n"
        report += "IDs referenciados no documento que não existem na tabela de Requisitos Funcionais:\n\n"
        report += "| RF Fantasma | Localização Aproximada |\n"
        report += "|---|---|\n"

        for rf_id in orphans:
            location = self._find_rf_location(text, rf_id)
            report += f"| {rf_id} | {location} |\n"

        report += f"\n**Ação:** Remover referências ou adicionar os RFs à tabela.\n\n"

        return {
            "summary": f"CRITICAL: RF_ORPHAN — {len(orphans)} IDs fantasmas: {orphans}",
            "report": report
        }

    def _check_failed_sections(self, text: str) -> Dict | None:
        """Detecta seções com marcadores de falha de geração."""
        failure_markers = [
            "GERAÇÃO FALHOU",
            "PASS_FAILED",
            "CONSOLIDAÇÃO FALHOU",
            "seção não produzida pelo modelo",
            "Ação necessária: Re-executar",
        ]

        found = []
        lines = text.split('\n')
        current_section = ""

        for line in lines:
            stripped = line.strip()
            if stripped.startswith('## '):
                current_section = stripped
            for marker in failure_markers:
                if marker in stripped and current_section:
                    if current_section not in found:
                        found.append(current_section)

        if not found:
            return None

        report = "### ❌ Seções com Geração Falha (CRITICAL)\n\n"
        report += "Estas seções contêm marcadores indicando que o modelo não produziu conteúdo:\n\n"
        for section in found:
            report += f"- {section}\n"
        report += f"\n**Ação:** Re-executar o pipeline com modelo maior ou mais contexto.\n\n"

        return {
            "summary": f"CRITICAL: FAILED_SECTIONS — {len(found)} seções com falha: {found}",
            "report": report
        }

    def _check_thin_sections(self, text: str, min_content_chars: int = 50) -> Dict | None:
        """Detecta seções com conteúdo muito curto (< min_content_chars)."""
        thin = []

        # Dividir por headings ##
        parts = re.split(r'(?=^## )', text, flags=re.MULTILINE)

        for part in parts:
            if not part.strip():
                continue

            lines = part.strip().split('\n')
            if not lines[0].startswith('## '):
                continue

            heading = lines[0].strip()
            content = '\n'.join(lines[1:])

            # Remover separadores de tabela e whitespace
            clean_content = re.sub(r'\|[-\s|]+\|', '', content)
            clean_content = re.sub(r'\s+', ' ', clean_content).strip()

            if len(clean_content) < min_content_chars:
                thin.append((heading, len(clean_content)))

        if not thin:
            return None

        report = "### ⚠️ Seções com Conteúdo Insuficiente\n\n"
        report += f"Seções com menos de {min_content_chars} caracteres de conteúdo útil:\n\n"
        report += "| Seção | Chars Úteis |\n"
        report += "|---|---|\n"
        for heading, chars in thin:
            report += f"| {heading} | {chars} |\n"
        report += f"\n**Ação:** Expandir estas seções com dados concretos.\n\n"

        return {
            "summary": f"WARNING: THIN_SECTIONS — {len(thin)} seções insuficientes",
            "report": report
        }

    def _check_tech_contradictions(self, text: str) -> Dict | None:
        """
        Detecta contradições na stack tecnológica.
        Ex: Seção de Constraints diz "PostgreSQL" mas tabela de Tech Stack diz "MongoDB".
        """
        contradictions = []

        for group_name, techs in self.TECH_GROUPS.items():
            found_techs = self._find_techs_in_text(text, techs)

            if len(found_techs) <= 1:
                continue

            # Verificar se múltiplas tecnologias do MESMO grupo são mencionadas
            # em contextos que sugerem escolha (não complementaridade)
            # Heurística: se aparecem em seções diferentes com papel similar
            sections_per_tech = {}
            for tech in found_techs:
                sections_per_tech[tech] = self._find_tech_sections(text, tech)

            # Se duas techs do mesmo grupo aparecem na mesma seção de Stack/Constraints,
            # pode ser complementar (ex: PostgreSQL + Redis). Mas se uma está em
            # "Constraints" e outra em "Tech Stack" como principal, é contradição.
            if group_name == "database":
                # Para DB, verificar se mesma camada usa techs diferentes
                constraint_techs = set()
                stack_techs = set()
                for tech, sections in sections_per_tech.items():
                    for section in sections:
                        if "constraint" in section.lower():
                            constraint_techs.add(tech)
                        if "tech stack" in section.lower():
                            stack_techs.add(tech)

                if constraint_techs and stack_techs:
                    diff = constraint_techs.symmetric_difference(stack_techs)
                    if diff and len(constraint_techs) == 1 and len(stack_techs) == 1:
                        if constraint_techs != stack_techs:
                            contradictions.append(
                                f"{group_name}: Constraints menciona "
                                f"{constraint_techs} mas Tech Stack usa {stack_techs}"
                            )

        if not contradictions:
            return None

        report = "### ⚠️ Contradições de Stack Tecnológica\n\n"
        report += "Possíveis inconsistências entre seções do documento:\n\n"
        for contradiction in contradictions:
            report += f"- {contradiction}\n"
        report += f"\n**Ação:** Verificar e alinhar referências tecnológicas.\n\n"

        return {
            "summary": f"WARNING: TECH_CONTRADICTION — {len(contradictions)} contradição(ões)",
            "report": report
        }

    def _check_rnf_metrics(self, text: str) -> Dict | None:
        """Detecta RNFs que não possuem métrica quantitativa na coluna Target."""
        # Localizar seção de RNFs
        rnf_section = self._extract_section(text, "## Requisitos Não-Funcionais")
        if not rnf_section:
            return None

        # Extrair linhas de tabela (excluindo headers e separadores)
        table_lines = [
            l for l in rnf_section.split('\n')
            if l.strip().startswith('|')
            and '---|' not in l
            and 'ID' not in l.split('|')[1] if len(l.split('|')) > 1 else False
        ]

        vague_rnfs = []
        vague_markers = ['a definir', '...', 'tbd', 'n/a', 'alto', 'baixo', 'bom', 'rápido']

        for line in table_lines:
            cells = [c.strip() for c in line.split('|') if c.strip()]
            if len(cells) < 4:
                continue

            rnf_id = cells[0] if cells[0].upper().startswith('RNF') else ""
            # A última ou penúltima célula geralmente é o Target
            target = cells[-1] if len(cells) >= 4 else ""

            if rnf_id and any(v in target.lower() for v in vague_markers):
                vague_rnfs.append((rnf_id, target))

        if not vague_rnfs:
            return None

        report = "### ⚠️ RNFs sem Métrica Quantitativa\n\n"
        report += "| RNF ID | Target Atual | Problema |\n"
        report += "|---|---|---|\n"
        for rnf_id, target in vague_rnfs:
            report += f"| {rnf_id} | {target} | Métrica vaga ou indefinida |\n"
        report += f"\n**Ação:** Substituir por métricas mensuráveis (ex: '<200ms', '>99.9%').\n\n"

        return {
            "summary": f"WARNING: VAGUE_RNFS — {len(vague_rnfs)} RNFs sem métrica quantitativa",
            "report": report
        }

    # ═══════════════════════════════════════════════════════
    # MÉTODOS AUXILIARES
    # ═══════════════════════════════════════════════════════

    def _extract_defined_rf_ids(self, text: str) -> Set[str]:
        """
        Extrai IDs RF-XX definidos em linhas de tabela de Requisitos Funcionais.
        Procura apenas dentro da seção de RFs para evitar falsos positivos.
        """
        rf_section = self._extract_section(text, "## Requisitos Funcionais")
        if not rf_section:
            return set()

        # Padrão: | RF-01 | ... | (no início de uma célula de tabela)
        pattern = r'\|\s*(RF-\d+)\s*\|'
        return set(re.findall(pattern, rf_section, re.IGNORECASE))

    def _extract_all_rf_references(self, text: str) -> Set[str]:
        """Extrai TODOS os IDs RF-XX mencionados em qualquer lugar do texto."""
        return set(re.findall(r'RF-\d+', text, re.IGNORECASE))

    def _find_rf_location(self, text: str, rf_id: str) -> str:
        """Encontra em qual seção um RF-ID é mencionado."""
        lines = text.split('\n')
        current_section = "(início)"

        for line in lines:
            if line.strip().startswith('## '):
                current_section = line.strip()
            if rf_id in line and not line.strip().startswith('## '):
                return current_section

        return "(não localizado)"

    def _extract_section(self, text: str, heading: str) -> str:
        """Extrai o conteúdo de uma seção específica (entre dois headings ##)."""
        pattern = re.escape(heading) + r'.*?(?=\n## |\Z)'
        match = re.search(pattern, text, re.DOTALL | re.IGNORECASE)
        return match.group(0) if match else ""

    def _find_techs_in_text(self, text: str, tech_list: List[str]) -> Set[str]:
        """Encontra quais tecnologias de uma lista aparecem no texto."""
        text_lower = text.lower()
        found = set()
        for tech in tech_list:
            # Busca com word boundary para evitar falsos positivos
            # Ex: "go" não deve casar com "going"
            if re.search(r'\b' + re.escape(tech) + r'\b', text_lower):
                found.add(tech)
        return found

    def _find_tech_sections(self, text: str, tech: str) -> List[str]:
        """Encontra em quais seções uma tecnologia é mencionada."""
        sections = []
        lines = text.split('\n')
        current_section = ""

        for line in lines:
            if line.strip().startswith('## '):
                current_section = line.strip()
            if tech.lower() in line.lower() and current_section:
                if current_section not in sections:
                    sections.append(current_section)

        return sections
```

