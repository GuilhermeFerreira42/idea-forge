            "## Requisitos Funcionais\n"
            "| ID | Requisito | Critério | Prioridade | Complexidade | Status |\n"
            "|---|---|---|---|---|---|\n"
            "| RF-01 | Busca | GET /api retorna 200 | Must | Low | ✅ |\n\n"
            "## Escopo MVP\n"
            "**Inclui:** RF-01, RF-05, RF-12\n\n"
            "Texto de preenchimento para garantir o mínimo de caracteres necessário."
        )
        report = self.checker.check_consistency(prd)
        assert "RF-05" in report
        assert "RF-12" in report
        assert "is_clean:** False" in report
        assert "CRITICAL" in report

    def test_no_false_positive_when_all_rfs_defined(self):
