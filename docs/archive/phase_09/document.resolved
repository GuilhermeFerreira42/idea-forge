import pytest
from src.agents.consistency_checker_agent import ConsistencyCheckerAgent


class TestConsistencyCheckerCleanPRD:
    """Testes com PRD limpo — deve passar sem problemas."""

    def setup_method(self):
        self.checker = ConsistencyCheckerAgent()

    def test_clean_prd_is_consistent(self):
        prd = (
            "## Requisitos Funcionais\n"
            "| ID | Requisito | Critério | Prioridade | Complexidade | Status |\n"
            "|---|---|---|---|---|---|\n"
            "| RF-01 | Busca | GET /api retorna 200 | Must | Low | ✅ |\n"
            "| RF-02 | Login | POST /auth retorna JWT | Must | Med | ✅ |\n"
            "| RF-03 | Perfil | GET /user retorna dados | Should | Low | ✅ |\n\n"
            "## Escopo MVP\n"
            "**Inclui:** RF-01, RF-02\n"
            "**NÃO inclui:** RF-03 (v2)\n\n"
            "## Requisitos Não-Funcionais\n"
            "| ID | Categoria | Requisito | Métrica | Target |\n"
            "|---|---|---|---|---|\n"
            "| RNF-01 | Performance | Latência API | p95 | <200ms |\n"
            "| RNF-02 | Disponibilidade | Uptime | mensal | >99.9% |\n\n"
            "## Constraints Técnicos\n"
            "- Linguagem: Python\n"
            "- Banco de dados: PostgreSQL\n\n"
            "## Arquitetura e Tech Stack\n"
            "| Camada | Tecnologia | Justificativa |\n"
            "|---|---|---|\n"
            "| Backend | FastAPI | Async nativo |\n"
            "| Banco | PostgreSQL | Integridade relacional |\n\n"
            "Conteúdo adicional para garantir que o PRD tenha mais de 100 caracteres e passe "
            "na verificação inicial de tamanho mínimo do checker."
        )
        report = self.checker.check_consistency(prd)
        assert "is_clean:** True" in report
        assert "CRITICAL" not in report


class TestConsistencyCheckerOrphanRFs:
    """Testes de detecção de IDs RF fantasmas."""

    def setup_method(self):
        self.checker = ConsistencyCheckerAgent()

    def test_detects_orphan_rf_in_escopo(self):
