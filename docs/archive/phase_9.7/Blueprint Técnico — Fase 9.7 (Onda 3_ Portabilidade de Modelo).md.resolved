# SEÇÃO 3 — TECH SPECS

## Modelo de Dados Completo

```python
# --- prompt_profiles.py ---

# Constantes de detecção de faixa por nome de modelo
SMALL_MODEL_KEYWORDS: List[str] = [
    "1b", "1.5b", "0.5b", "gemma3:1b", "gemma:2b", "phi3:mini",
    "qwen2.5:1b", "qwen2.5:1.5b", "tinyllama"
]
# Invariante: qualquer string em SMALL_MODEL_KEYWORDS resulta em PROFILE_SMALL

MEDIUM_MODEL_KEYWORDS: List[str] = [
    "3b", "2b", "4b", "qwen2.5:3b", "phi3:3b", "gemma:7b", "gemma3:4b"
]
# Invariante: qualquer string em MEDIUM_MODEL_KEYWORDS resulta em PROFILE_MEDIUM

# DEFAULT: qualquer modelo não detectado como SMALL ou MEDIUM → PROFILE_LARGE

# --- atomic_task_decomposer.py ---

@dataclass
class AtomicCallResult:
    """Resultado de uma chamada atômica individual."""
    row_index: int          # Índice da linha/item gerado
    content: str            # String markdown da linha/bullet gerado
    success: bool           # True se não vazio e não é placeholder
    chars: int              # len(content)
    # Invariante: se success == True, então len(content) > 0
    # Invariante: se success == False, content == "" ou é placeholder

@dataclass
class DecompositionPlan:
    """Plano de decomposição para uma seção."""
    section_heading: str        # "## Requisitos Funcionais"
    decomposition_type: Literal["TABLE", "BULLETS"]
    columns: List[str]          # Para TABLE: ["ID", "Requisito", "Critério", ...]
    bullet_labels: List[str]    # Para BULLETS: ["RF-01", "RF-02", ...]
    target_count: int           # Número alvo de linhas/bullets
    system_directive: str       # Prompt de sistema truncado ao perfil
    context_snippet: str        # Contexto truncado a profile.max_context_chars
    max_tokens_per_call: int    # profile.max_output_tokens (≤ 400 para SMALL)
```

